# Docker Compose env for Clawdbot (Windows)
# 1) Copy this file to `.env`
# 2) Fill values
# 3) Run: scripts\win\clawdbot-restart-gateway.bat
#
# Notes:
# - For OpenAI-compatible proxies, base URL is usually `https://host/path/v1`
# - Use forward slashes in Windows paths (Docker Desktop friendly)

CLAWDBOT_IMAGE=clawdbot:local

# Mounted dirs (persist config + workspace)
CLAWDBOT_CONFIG_DIR=D:/xiangmu/clawdbot/.runtime/config
CLAWDBOT_WORKSPACE_DIR=D:/xiangmu/clawdbot/.runtime/workspace

# Gateway bind/ports
CLAWDBOT_GATEWAY_BIND=lan
CLAWDBOT_GATEWAY_PORT=18789
CLAWDBOT_BRIDGE_PORT=18790

# Control UI / API token (choose a strong random string)
CLAWDBOT_GATEWAY_TOKEN=change-me

# OpenAI-compatible upstream
CLAWDBOT_OPENAI_API_KEY=
CLAWDBOT_OPENAI_BASE_URL=https://your-proxy-host.example.com/v1

# Optional providers (leave empty if unused)
CLAWDBOT_OPENROUTER_API_KEY=
CLAUDE_AI_SESSION_KEY=
CLAUDE_WEB_SESSION_KEY=
CLAUDE_WEB_COOKIE=
